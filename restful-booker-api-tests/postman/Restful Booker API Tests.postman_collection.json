    {
      "name": "Update Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Booking was updated\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.firstname).to.eql(\"John\");\r",
              "    pm.expect(response.lastname).to.eql(\"Updated\");\r",
              "    pm.expect(response.totalprice).to.eql(300);\r",
              "    pm.expect(response.depositpaid).to.eql(false);\r",
              "    pm.expect(response.additionalneeds).to.eql(\"Dinner\");\r",
              "});\r",
              "\r",
              "pm.test(\"Booking dates were updated\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.bookingdates.checkin).to.eql(\"2026-08-01\");\r",
              "    pm.expect(response.bookingdates.checkout).to.eql(\"2026-08-10\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
